{
	"framework": "vite",
	"installCommand": "npm ci",
	"buildCommand": "npm run build",
	"outputDirectory": "dist",
	"functions": {
		"api/entry.ts": {
			"maxDuration": 60
		}
	},
	"rewrites": [
		{ "source": "/api/:path*", "destination": "/api/entry" },
		{ "source": "/((?!api/).*)", "destination": "/index.html" }
	]
}
