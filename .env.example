# .env.example
# Database & Cache
DATABASE_URL=postgresql://username:password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require
# DATABASE_FILE=orren.db
REDIS_URL=redis://localhost:6379/0

# AI Models & Keys
DEEPSEEK_API_KEY=
# Legacy env name supported for existing deployments; store the DeepSeek key here if already configured.
AICREDITS_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Authentication
JWT_SECRET=super_secret_change_me
FERNET_KEY=  # Generated via cryptography.fernet.generate_key()
ENCRYPTION_KEY=replace_with_64_char_hex_key
PORT=3000
VITE_HMR_PORT=24679
DISABLE_HMR=false
VITE_API_BASE_URL=http://localhost:3001

# Superadmin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
# ADMIN_PASSWORD is first boot/local bootstrap only. Prefer ADMIN_PASSWORD_HASH in production.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=change_this_admin_cookie_secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/callback/google
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=
GITHUB_SCAN_MODEL=deepseek-chat
GITHUB_SCAN_PROMPT_TOKENS=60000
GITHUB_SCAN_INPUT_CHAR_BUDGET=240000
GITHUB_SCAN_MAX_TOKENS=20000
GITHUB_SCAN_TEMPERATURE=0.1
GITHUB_SCAN_TOP_P=0.95
GITHUB_SCAN_TIMEOUT_MS=25000
GITHUB_SCAN_INITIAL_RESPONSE_TIMEOUT_MS=8000
SCENARIO_GENERATION_MODEL=deepseek-chat
SCENARIO_STEP_EVALUATION_MODEL=deepseek-chat
CODING_PROBLEM_GENERATION_MODEL=deepseek-chat
CODING_EVALUATION_MODEL=deepseek-chat
CODE_EVALUATION_MODEL=deepseek-chat
CODE_EVALUATION_PROMPT_TOKENS=5000
CODE_EVALUATION_MAX_TOKENS=500
CODE_EVALUATION_TIMEOUT_MS=8000
PRACTICE_GENERATION_ROUTE_TIMEOUT_MS=55000
PRACTICE_COMPREHENSION_TIMEOUT_MS=18000
PRACTICE_CODE_READING_TIMEOUT_MS=18000
GAP_ANALYSIS_MODEL=deepseek-chat
GAP_ANALYSIS_PROMPT_TOKENS=8000
GAP_ANALYSIS_MAX_TOKENS=4000

# Razorpay Billing
# Local development: use Razorpay test keys here. Production: add live keys in Vercel Project Settings > Environment Variables.
# Keep key id public only through server responses; never expose RAZORPAY_KEY_SECRET to the client.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Set to 9900 after the Razorpay Rs.1 production smoke test is complete.
MONTHLY_PLAN_AMOUNT_PAISE=9900

# Infrastructure
TEMPORAL_HOST=localhost:7233
FRONTEND_URL=http://localhost:3000
USD_TO_INR_RATE=84
NODE_ENV=production
