# .env.example
# Database & Cache
DATABASE_URL=postgresql://username:password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require
# DATABASE_FILE=orren.db
REDIS_URL=redis://localhost:6379/0

# AI Models & Keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
AICREDITS_API_KEY=
AICREDITS_BASE_URL=https://api.aicredits.in/v1
OPENAI_COMPAT_BASE_URL=https://api.aicredits.in/v1

ANTHROPIC_MODELS_ALLOWED=claude-3-5-sonnet-20241022,claude-3-5-haiku-20241022

# Authentication
JWT_SECRET=super_secret_change_me
FERNET_KEY=  # Generated via cryptography.fernet.generate_key()
ENCRYPTION_KEY=replace_with_64_char_hex_key
PORT=3000
VITE_HMR_PORT=24679
DISABLE_HMR=false

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/callback/google
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=
GITHUB_SCAN_MODEL=deepseek/deepseek-chat
GITHUB_SCAN_PROMPT_TOKENS=60000
GITHUB_SCAN_INPUT_CHAR_BUDGET=240000
GITHUB_SCAN_MAX_TOKENS=20000
GITHUB_SCAN_TEMPERATURE=0.1
GITHUB_SCAN_TOP_P=0.95
GITHUB_SCAN_TIMEOUT_MS=300000
GITHUB_SCAN_INITIAL_RESPONSE_TIMEOUT_MS=15000
CODE_EVALUATION_MODEL=deepseek/deepseek-chat
CODE_EVALUATION_PROMPT_TOKENS=5000
CODE_EVALUATION_MAX_TOKENS=3000
GAP_ANALYSIS_MODEL=anthropic/claude-3-5-haiku-20241022
GAP_ANALYSIS_PROMPT_TOKENS=8000
GAP_ANALYSIS_MAX_TOKENS=4000

# Razorpay Billing
# Local development: use Razorpay test keys here. Production: add live keys in Vercel Project Settings > Environment Variables.
# Keep key id public only through server responses; never expose RAZORPAY_KEY_SECRET to the client.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Infrastructure
TEMPORAL_HOST=localhost:7233
FRONTEND_URL=http://localhost:3000
USD_TO_INR_RATE=84
NODE_ENV=production
