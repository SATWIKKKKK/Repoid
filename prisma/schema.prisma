generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RepoScanStatus {
  pending
  complete
  failed
}

model User {
  id                   String                @id
  githubRepos          GithubRepo[]
  repoScanJobs         RepoScanJob[]
  userRepoInteractions UserRepoInteraction[]
  subscription         Subscription?
  billingOrders        BillingOrder[]
  practiceTracks       PracticeTrack[]

  @@map("users")
}

model PracticeTrack {
  id                 String        @id @default(uuid())
  userId             String        @map("user_id")
  domain             String
  currentModuleIndex Int           @default(0) @map("current_module_index")
  completedModuleIds Json          @default("[]") @map("completed_module_ids")
  startedAt          DateTime      @default(now()) @map("started_at") @db.Timestamptz(6)
  lastActiveAt       DateTime      @default(now()) @map("last_active_at") @db.Timestamptz(6)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  modules            TrackModule[]

  @@unique([userId, domain])
  @@index([userId, lastActiveAt])
  @@map("practice_tracks")
}

model TrackModule {
  id          String        @id @default(uuid())
  trackId     String        @map("track_id")
  moduleKey   String        @map("module_key")
  moduleTitle String        @map("module_title")
  moduleIndex Int           @default(0) @map("module_index")
  status      String        @default("locked")
  score       Int?
  questionIds Json          @default("[]") @map("question_ids")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  track       PracticeTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([trackId, moduleKey])
  @@index([trackId, moduleIndex])
  @@map("track_modules")
}

model Subscription {
  id                       String    @id @default(uuid())
  userId                   String    @unique @map("user_id")
  plan                     String    @default("free")
  status                   String    @default("active")
  provider                 String    @default("manual")
  razorpayCustomerId       String?   @map("razorpay_customer_id")
  razorpaySubscriptionId   String?   @map("razorpay_subscription_id")
  razorpayPaymentId        String?   @map("razorpay_payment_id")
  currentPeriodEnd         DateTime? @map("current_period_end") @db.Timestamptz(6)
  billingInterval          String?   @default("monthly") @map("billing_interval")
  seats                    Int       @default(1)
  expiredPlan              String?   @map("expired_plan")
  expiredBillingInterval   String?   @map("expired_billing_interval")
  expiredAt                DateTime? @map("expired_at") @db.Timestamptz(6)
  expiryNoticeSeenAt       DateTime? @map("expiry_notice_seen_at") @db.Timestamptz(6)
  renewalNoticeSeenAt      DateTime? @map("renewal_notice_seen_at") @db.Timestamptz(6)
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("subscriptions")
}

model BillingOrder {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  razorpayOrderId   String    @unique @map("razorpay_order_id")
  plan              String
  billingInterval   String    @map("billing_interval")
  seats             Int       @default(1)
  amountPaise       Int       @map("amount_paise")
  currency          String    @default("INR")
  status            String    @default("created")
  razorpayPaymentId String?   @map("razorpay_payment_id")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  verifiedAt        DateTime? @map("verified_at") @db.Timestamptz(6)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("billing_orders")
}

model GithubRepo {
  id              String                 @id @default(uuid())
  userId          String                 @map("user_id")
  repoUrl         String                 @map("repo_url")
  repoName        String                 @map("repo_name")
  detectedStack   Json                   @default("[]") @map("detected_stack")
  status          RepoScanStatus         @default(pending)
  scannedAt       DateTime               @default(now()) @map("scanned_at") @db.Timestamptz(6)
  rawAnalysisJSON Json?                  @map("raw_analysis_json")
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionSet     RepoQuestionSet?
  interactions    UserRepoInteraction[]

  @@unique([userId, repoUrl])
  @@index([userId, scannedAt])
  @@map("github_repos")
}

model RepoQuestionSet {
  id             String     @id @default(uuid())
  repoId         String     @unique @map("repo_id")
  generatedAt    DateTime   @default(now()) @map("generated_at") @db.Timestamptz(6)
  projectSummary String     @map("project_summary")
  totalQuestions Int        @default(0) @map("total_questions")
  sectionsJSON   Json       @map("sections_json")
  repo           GithubRepo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@map("repo_question_sets")
}

model RepoScanJob {
  id           String         @id @default(uuid())
  userId       String         @map("user_id")
  repoUrl      String         @map("repo_url")
  status       RepoScanStatus @default(pending)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt  DateTime?      @map("completed_at") @db.Timestamptz(6)
  errorMessage String?        @map("error_message")
  retryCount   Int            @default(0) @map("retry_count")
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@map("repo_scan_jobs")
}

model UserRepoInteraction {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  repoId     String     @map("repo_id")
  questionId String     @map("question_id")
  viewedAt   DateTime   @default(now()) @map("viewed_at") @db.Timestamptz(6)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo       GithubRepo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([userId, repoId, viewedAt])
  @@map("user_repo_interactions")
}
